{
  "name": "mlangenigroup/machinjiri",
  "description": "A full PHP Framework",
  "type": "framework",
  "language": "PHP",
  "keywords": ["php", "framework", "mlangeni", "machinjiri"],
  "homepage": "https://github.com/preciouslyson/machinjiri",
  "version" : "1.0.0",
  "license": "MIT",
  "authors": [
    {
      "name": "Precious Lyson",
      "email": "precious.lyson@gmail.com",
      "homepage": "https://www.facebook.com/precious.lyson.developer",
      "role": "Developer"
    }
  ],
  "support": {
    "email": "Mlangeniqme@gmail.com",
    "issues": "https://github.com/preciouslyson/machinjiri/issues",
    "source": "https://github.com/preciouslyson/machinjiri"
  },
  "require": {
    "php": "^8.0.6",
    "phpmailer/phpmailer": "*"
  },
  "require-dev": {
    "phpunit/phpunit" : "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Mlangeni\\Machinjiri\\Core\\": "src/Machinjiri/",
      "Mlangeni\\Machinjiri\\App\\" : "app/"
    }
  },
  "autoload-dev": {
    "psr-4" : {
      "Mlangeni\\Machinjiri\\Tests\\" : "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "archive": {
    "exclude": [
      "/tests",
      "/docs",
      "/.gitignore",
      "/.env",
      "/node_modules",
      "/.idea"
    ]
  }
}
