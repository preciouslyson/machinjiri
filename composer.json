{
  "name": "machinjiri/framework",
  "description": "Machinjiri is a lightweight, flexible PHP framework for rapid web development.",
  "type": "library",
  "license": "proprietary",
  "version": "2.1.3",
  "authors": [
    {
      "name": "Precious Lyson",
      "email": "precious.lyson@gmail.com",
      "role": "Developer"
    },
    {
      "name": "Mlangeni Group",
      "email": "mlangenigroupqm@gmail.com",
      "role": "Company"
    }
  ],
  "require": {
    "php": "^8.2",
    "phpmailer/phpmailer": "^7.0.1",
    "symfony/console": "^5.3",
    "symfony/filesystem": "^5.3",
    "symfony/process": "^5.3",
    "predis/predis" : "^3.3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "mockery/mockery": "^1.5",
    "fakerphp/faker": "^1.20",
    "brianium/paratest": "^6.6"
  },
  "autoload": {
    "psr-4": {
      "Mlangeni\\Machinjiri\\": "src/Machinjiri/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Mlangeni\\Machinjiri\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "keywords": [
    "mlangeni",
    "machinjiri",
    "preciouslyson",
    "framework",
    "php",
    "lightweight",
    "web",
    "development"
  ]
}
